{
    "name": "medical-research-tracker",
    "version": "0.1.87",
    "private": true,
    "description": "Personal health records and medical research discovery tool",
    "type": "module",
    "main": "electron/main.cjs",
    "scripts": {
        "dev": "vite --host",
        "build": "vite build",
        "preview": "vite preview",
        "server": "node server/index.js",
        "start": "npm run server & npm run dev",
        "electron:dev": "concurrently -k \"cross-env NODE_ENV=development npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
        "electron:build": "npm run build && node build-server.js && electron-builder",
        "electron:build:mac": "npm run build && node build-server.js && electron-builder --mac",
        "postinstall": "npx @electron/rebuild -f -m ./node_modules/sqlite3"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^7.3.8",
        "@mui/material": "^7.3.8",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "cytoscape": "^3.33.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.3",
        "openai": "^6.21.0",
        "playwright": "^1.58.2",
        "react-cytoscapejs": "^2.0.0",
        "reactflow": "^11.11.4",
        "recharts": "^3.7.0",
        "sqlite3": "^6.0.1",
        "three": "^0.183.2"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^4.2.1",
        "electron": "^41.1.1",
        "electron-builder": "^26.8.1",
        "esbuild": "^0.27.5",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "vite": "^5.0.8"
    }
}